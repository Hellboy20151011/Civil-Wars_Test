# Datenbankzugangsdaten
DB_USER=postgres
DB_HOST=localhost
DB_NAME=civil_wars_test
DB_PASSWORD=dein_passwort
DB_PORT=5432

# Datenbankpool-Größe (optional, Default: 10)
POOL_MAX=10

# Serverport
PORT=3000

# JWT
# Muss mindestens 32 Zeichen lang sein!
JWT_SECRET=change_this_to_a_long_random_secret_before_production_min32chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN_MS=2592000000

# CORS
# In Produktion auf die echte Frontend-URL setzen, z. B. https://civil-wars.example.com
# Mehrere Origins können komma-separiert angegeben werden (z. B. Backend + Vite Dev-Server)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Rate Limiting (optional – Defaults sind in config.js dokumentiert)
# RATE_AUTH_WINDOW_MS=900000   # 15 Minuten
# RATE_AUTH_MAX=20
# RATE_API_WINDOW_MS=60000     # 1 Minute
# RATE_API_MAX=120

# Gameloop-Tick-Intervall in Millisekunden
# TICK_INTERVAL_MS=60000       # Dev: 1 Min | Prod-Default: 10 Min (600000)

# Performance
# Cache-TTL für Stammdaten (`building_types`, `unit_types`, `resource_types`)
# REFERENCE_DATA_CACHE_TTL_MS=300000

# Umgebung
NODE_ENV=development

# Logging
# z. B. debug (lokal), info (produktion), warn, error
LOG_LEVEL=debug

# API-Dokumentation (Swagger UI)
# Aktiviert die Dev-Route /api-docs zum Rendern von docs/openapi.yaml
ENABLE_SWAGGER_UI=true

# Karten-System
# Größe des Koordinatengitters (1–MAP_GRID_SIZE); Default: 999
# MAP_GRID_SIZE=999
# Maximale sinnvolle Spielerzahl auf dem Server (wird an Frontend geliefert)
# MAP_MAX_PLAYERS=1000

# Sicherheit – Account-Lockout
# Anzahl fehlgeschlagener Login-Versuche bis der Account gesperrt wird (Default: 5)
# MAX_FAILED_LOGINS=5
# Sperrdauer in Millisekunden (Default: 900000 = 15 Minuten)
# LOCKOUT_DURATION_MS=900000
