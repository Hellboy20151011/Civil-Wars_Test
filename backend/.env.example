# Datenbankzugangsdaten
DB_USER=postgres
DB_HOST=localhost
DB_NAME=civil_wars_test
DB_PASSWORD=dein_passwort
DB_PORT=5432

# Datenbankpool-Größe (optional, Default: 10)
POOL_MAX=10

# Serverport
PORT=3000

# JWT
# Muss mindestens 32 Zeichen lang sein!
JWT_SECRET=change_this_to_a_long_random_secret_before_production_min32chars
JWT_EXPIRES_IN=7d

# CORS
# In Produktion auf die echte Frontend-URL setzen, z. B. https://civil-wars.example.com
# Mehrere Origins können komma-separiert angegeben werden (z. B. Backend + Vite Dev-Server)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Rate Limiting (optional – Defaults sind in config.js dokumentiert)
# RATE_AUTH_WINDOW_MS=900000   # 15 Minuten
# RATE_AUTH_MAX=20
# RATE_API_WINDOW_MS=60000     # 1 Minute
# RATE_API_MAX=120

# Gameloop-Tick-Intervall in Millisekunden
# TICK_INTERVAL_MS=60000       # Dev: 1 Min | Prod-Default: 10 Min (600000)

# Performance
# Cache-TTL für Stammdaten (`building_types`, `unit_types`, `resource_types`)
# REFERENCE_DATA_CACHE_TTL_MS=300000

# Umgebung
NODE_ENV=development
