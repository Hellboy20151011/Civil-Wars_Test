{
    "name": "civil-wars-backend",
    "version": "1.0.0",
    "type": "module",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "node --watch server.js",
        "predev:full": "node scripts/free-port.js 3000 5173",
        "dev:full": "concurrently -n backend,frontend -c blue,green \"npm run dev\" \"npm --prefix ../frontend run dev\"",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test"
    },
    "dependencies": {
        "bcrypt": "^6.0.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-rate-limit": "^8.4.1",
        "js-yaml": "^4.1.1",
        "jsonwebtoken": "^9.0.3",
        "pg": "^8.12.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "pino-pretty": "^13.1.3",
        "swagger-ui-express": "^5.0.1",
        "zod": "^4.4.2"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.59.1",
        "@vitest/coverage-v8": "^4.1.5",
        "concurrently": "^9.2.1",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.3",
        "vitest": "^4.1.5",
        "wait-on": "^9.0.5"
    }
}
